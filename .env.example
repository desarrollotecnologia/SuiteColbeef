# Copia a .env y rellena (el archivo .env no se sube a Git).
# Usado por server.js en la raíz del proyecto (proxy Gemini + admin).

PORT=3000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Contraseña maestra de ejemplo (cambiar en producción): Colbeef2026*
# Usa comillas simples alrededor del hash (los $ de bcrypt si no pueden romperse al cargar el .env)
ADMIN_PASSWORD_HASH='$2y$12$QTSmU3LSNSeqI/UuErBPLeznjlBi5N8d3uOnnQiolC44SX/Pyzhlu'
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES=8h
ADMIN_COOKIE_NAME=workbeef_admin_token

NODE_ENV=development
