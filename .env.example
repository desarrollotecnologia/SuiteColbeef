# Copia a .env y rellena (el archivo .env no se sube a Git).
# Usado por server.js en la raíz del proyecto (proxy Gemini + admin).

PORT=3000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Contraseña maestra de ejemplo (cambiar en producción): Colbeef2026*
# Recomendado: MASTER_PASSWORD_HASH_B64 (php laravel/scripts/make-master-hash.php "tu_clave")
ADMIN_PASSWORD_HASH_B64=
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES=8h
ADMIN_COOKIE_NAME=workbeef_admin_token

NODE_ENV=development
